{
  "name": "mtp-workbench",
  "version": "0.1.0",
  "description": "MTP Workbench — Local methodology workspace between AI platforms",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
