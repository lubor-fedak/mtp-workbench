    "dexie": "^4.3.0",
    "lucide-svelte": "^0.577.0",
    "svelte": "^5.53.8",
    "uuid": "^13.0.0",
    "wxt": "^0.20.18"
  },
  "devDependencies": {
    "@tsconfig/svelte": "^5.0.8",
    "@types/uuid": "^10.0.0",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3"
  }
}
